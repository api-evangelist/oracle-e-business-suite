        },
        "unitPrice": {
          "@id": "schema:price",
          "@type": "xsd:decimal"
        },
        "unitMeasLookupCode": {
          "@id": "ebs:unitOfMeasure",
          "@type": "xsd:string"
        },
        "needByDate": {
          "@id": "ebs:needByDate",
          "@type": "xsd:date"
        }
      }
    },

